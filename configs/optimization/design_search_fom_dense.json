{
  "study_name": "fom_dense_sweep_v2",
  "description": "Sweep manufacturing parameters to maximize FOM for 67-channel BGO/BaF2 dense composite pixel at 25mm depth, correct xz-tilt (y-axis rotation).",
  "base_config": "configs/benchmarks/composite_bgo_baf2_dense_511keV.json",
  "n_events": 2000,
  "seed": 42,
  "search_space": {
    "numeric_parameters": [
      {"name": "manufacturing.tilt_deg", "min": 0.0, "max": 5.0, "step": 0.5},
      {"name": "manufacturing.groove_width_mm", "min": 0.001, "max": 0.2, "step": 0.02, "default": 0.025},
      {"name": "manufacturing.wall_width_mm", "min": 0.001, "max": 0.05, "step": 0.005, "default": 0.02},
      {"name": "manufacturing.matrix_edge_width_mm", "min": 0.001, "max": 0.05, "step": 0.005, "default": 0.005},
      {"name": "manufacturing.n_channels", "min": 45, "max": 90, "step": 5, "default": 67},
      {"name": "pixel_z_mm", "min": 25.0, "max": 25.0}
    ],
    "categorical_parameters": []
  },
  "objective": {
    "name": "figure_of_merit",
    "direction": "maximize"
  },
  "constraints": [
    {
      "type": "manufacturing_width",
      "params": {
        "groove": "manufacturing.groove_width_mm",
        "wall": "manufacturing.wall_width_mm",
        "matrix_edge": "manufacturing.matrix_edge_width_mm",
        "n_channels": "manufacturing.n_channels",
        "pixel_width_mm": 3.0,
        "default_groove": 0.025,
        "default_wall": 0.02,
        "default_matrix_edge": 0.005,
        "default_n_channels": 67
      }
    }
  ],
  "solver": {
    "method": "adaptive",
    "n_evaluations": 30,
    "n_initial": 10,
    "seed": 0
  }
}
